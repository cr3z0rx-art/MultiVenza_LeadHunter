# ── Supabase ──────────────────────────────────────────────────────────────────
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Publishable key — Supabase Dashboard → Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Service role key — NUNCA en frontend, solo server-side
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Sync API (shared with Python scrapers) ─────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SYNC_API_KEY=your-secret-sync-key-here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
